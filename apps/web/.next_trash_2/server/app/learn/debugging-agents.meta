{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/learn/layout,_N_T_/learn/[slug]/layout,_N_T_/learn/[slug]/page,_N_T_/learn/debugging-agents"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/learn/$d$slug/__PAGE__",
    "/learn/$d$slug",
    "/learn",
    "/_index",
    "/_head"
  ]
}