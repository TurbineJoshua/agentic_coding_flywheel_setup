{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/troubleshooting/layout,_N_T_/troubleshooting/page,_N_T_/troubleshooting"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/troubleshooting/__PAGE__",
    "/troubleshooting",
    "/_index",
    "/_head"
  ]
}